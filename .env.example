# SMTP credentials for the Request Appointment form (lib/env.ts asserts these exist).
# Set the REAL values in Vercel → Project → Settings → Environment Variables
# for ALL environments (Production, Preview, Development). Never commit real secrets.
#
# Port 465 = implicit SSL (recommended). Port 587 = STARTTLS.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Optional: override the From/To addresses (defaults to the clinic email in lib/site.ts).
# SMTP_FROM=
# CONTACT_TO=
